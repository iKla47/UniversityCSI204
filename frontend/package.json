{
    "name": "web-frontend",
    "version": "prototype",
    "homepage": "https://ikla47.github.io/UniversityCSI204",
    "private": true,
    "type": "module",
    "imports": 
    {
        "#asset/*": ["./src/asset/*"],
        "#component/*": ["./src/component/*"],
        "#context/*": ["./src/context/*"],
        "#hook/*": ["./src/hook/*"],
        "#page/*": ["./src/page/*"],
        "#type/*": ["./src/type/*"],
        "#util/*": ["./src/util/*"]
    },
    "scripts": 
    {
        "site:dev": "vite --host --debug hmr",
        "site:build": "tsc && vite build",
        "site:preview": "vite preview",
        "site:predeloy": "npm run build",
        "doc:dev": "vitepress dev src/doc --port 50001 --host",
        "doc:build": "vitepress build src/doc",
        "doc:preview": "vitepress preview src/doc",

        "dev": "concurrently \"npm run site:dev\" \"npm run doc:dev\"",
        "build": "npm run site:build && npm run doc:build",
        "deploy": "gh-pages -d build",
        "lint": "eslint ."
    },
    "dependencies": 
    {
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-router": "8.1.0",
        "styled-components": "6.4.3",
        "tailwindcss": "4.3.2",
        "lucide-react": "1.24.0",
        "@tanstack/react-query": "5.101.2"
    },
    "devDependencies": 
    {
        "gh-pages": "6.3.0",
        "mermaid": "11.16.0",
        "vite": "8.1.4",
        "vitepress": "1.6.4",
        "vitepress-plugin-mermaid": "2.0.17",
        "eslint": "9.39.4",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.1.1",
        "eslint-plugin-react-compiler": "19.1.0-rc.2",
        "typescript": "6.0.3",
        "typescript-eslint": "8.63.0",
        "jiti": "2.7.0",
        "globals": "17.7.0",
        "concurrently": "10.0.3",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@types/eslint": "9.6.1",
        "@vitejs/plugin-react": "6.0.2",
        "@tailwindcss/vite": "4.3.2"
    },
    "resolutions": 
    {
        "styled-components": "^6"
    }
}