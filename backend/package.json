{
    "name": "web-backend",
    "version": "prototype",
    "type": "module",
    "private": true,
    "keywords": [],
	
    "main": "./src/app.ts",
    "imports": 
    {
        "#controller/*": "./src/controller/*",
        "#core/*": "./src/core/*",
        "#model/*": "./src/model/*",
        "#router/*": "./src/router/*",
        "#type/*": "./src/type/*"
    },
    "scripts": 
	{
        "start": "node \"./src/app.ts\"",
        "seed": "node \"./src/appSeed.ts\"",
        "lint": "eslint .",
        "debug": 
            "node --inspect --watch ./src/app.ts --require ts-node/register",
        "dev": 
            "node --inspect --watch ./src/app.ts --require ts-node/register"
    },
    "dependencies": 
	{
        "compression": "1.8.1",
        "cors": "2.8.6",
        "dotenv": "17.4.2",
        "express": "5.2.1",
        "express-rate-limit": "8.5.2",
        "helmet": "8.2.0",
        "mysql2": "3.22.6",
        "ws": "8.21.0"
    },
    "devDependencies": 
	{
        "@types/compression": "1.8.1",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/node": "26.1.1",
        "@types/ws": "8.18.1",
        "@eslint/js": "10.0.1",
        "eslint": "10.6.0",
        "ts-node": "10.9.2",
        "typescript": "6.0.3",
        "typescript-eslint": "8.63.0",
        "jiti": "2.7.0",
        "globals": "17.7.0"
    }
}
