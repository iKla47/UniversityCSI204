{
    "name": "web-backend",
    "version": "prototype",
    "type": "module",
    "private": true,
    "keywords": [],
	
    "main": "./src/app.ts",
    "imports": 
    {
        "#controller/*": "./src/controller/*",
        "#core/*": "./src/core/*",
        "#model/*": "./src/model/*",
        "#router/*": "./src/router/*",
        "#type/*": "./src/type/*"
    },
    "scripts": 
	{
        "start": "node \"./src/app.ts\"",
        "seed": "node \"./src/appSeed.ts\"",
        "lint": "eslint .",
        "debug": 
            "node --inspect --watch ./src/app.ts --require ts-node/register",
        "dev": 
            "node --inspect --watch ./src/app.ts --require ts-node/register"
    },
    "dependencies": 
	{
        "compression": "1.8.1",
        "cors": "2.8.6",
        "express": "5.2.1",
        "express-rate-limit": "8.5.2",
        "ws": "8.21.1",
        "bcrypt": "6.0.0",
        "formidable": "3.5.4",

        "jose": "6.2.4",
        "helmet": "8.3.0",
        "mysql2": "3.23.1",
        "dotenv": "17.4.2"
    },
    "devDependencies": 
	{
        "@types/compression": "1.8.1",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/ws": "8.18.1",
        "@types/bcrypt": "6.0.0",
        "@types/formidable": "3.5.1",
        "@types/node": "26.1.1",
        "@eslint/js": "10.0.1",
        "@typescript/native": "npm:typescript@7.0.2",
        "typescript": "npm:@typescript/typescript6@6.0.2",

        "eslint": "10.7.0",
        "ts-node": "10.9.2",
        "typescript-eslint": "8.65.0",
        "jiti": "2.7.0",
        "globals": "17.7.0"
    }
}
