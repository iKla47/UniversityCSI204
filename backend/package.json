{
    "name": "project-backend",
    "version": "prototype",
    "type": "module",
    "private": true,
    "keywords": [],
	
    "main": "./src/App.ts",
    "imports": 
    {
        "#Controller/*": "./src/Controller/*",
        "#Core/*": "./src/Core/*",
        "#Model/*": "./src/Model/*",
        "#Router/*": "./src/Router/*",
        "#Type/*": "./src/Type/*"
    },
    "scripts": 
	{
        "start": "node \"./src/App.ts\"",
        "seed": "node \"./src/AppSeed.ts\"",
        "debug": "nodemon --watch src ./src/App.ts -r ts-node/register --inspect",
        "dev": "nodemon --watch src ./src/App.ts -r ts-node/register --inspect",
        "lint": "eslint ."
    },
    "dependencies": 
	{
        "bcrypt": "6.0.0",
        "compression": "1.8.1",
        "cors": "2.8.6",
        "dotenv": "17.4.2",
        "express": "5.2.1",
        "express-rate-limit": "8.3.2",
        "helmet": "8.1.0",
        "jsonwebtoken": "9.0.3",
        "mysql2": "3.22.0",
        "ws": "8.20.0",
        "multer": "2.1.1"
    },
    "devDependencies": 
	{
        "@types/bcrypt": "6.0.0",
        "@types/compression": "1.8.1",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/jsonwebtoken": "9.0.10",
        "@types/node": "25.6.0",
        "@types/ws": "8.18.1",
        "@eslint/js": "10.0.1",
        "@types/multer": "2.1.0",
        "eslint": "10.2.0",
        "nodemon": "3.1.14",
        "ts-node": "10.9.2",
        "typescript": "6.0.2",
        "typescript-eslint": "8.58.1",
        "jiti": "2.6.1",
        "globals": "17.5.0",
        "prettier": "3.8.2",
        "prettier-eslint": "16.4.2"
